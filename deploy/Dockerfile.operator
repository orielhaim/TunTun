FROM rust:1.96-bookworm AS builder

WORKDIR /src
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/

RUN cargo fetch
RUN cargo build --release --package tunnet-operator \
    && strip target/release/tunnet-operator

FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /src/target/release/tunnet-operator /usr/local/bin/tunnet-operator

EXPOSE 8080 9443

ENTRYPOINT ["tunnet-operator"]
CMD ["run"]
