FROM rust:1.97-bookworm AS builder

WORKDIR /src
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/

RUN cargo fetch
RUN cargo build --release --package tunnet-relay \
    && strip target/release/tunnet-relay

FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /src/target/release/tunnet-relay /usr/local/bin/tunnet-relay

EXPOSE 443 80

ENTRYPOINT ["tunnet-relay"]
CMD ["run"]
