{
  "name": "@tuntundev/sdk",
  "version": "0.3.0",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "Apache-2.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "engines": {
    "node": ">= 18"
  },
  "napi": {
    "binaryName": "tuntun-node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release --manifest-path ./Cargo.toml",
    "build:debug": "napi build --platform --manifest-path ./Cargo.toml",
    "create-npm-dirs": "napi create-npm-dirs",
    "prepublishOnly": "napi prepublish -t npm --no-gh-release",
    "version": "napi version"
  },
  "optionalDependencies": {
    "@tuntundev/sdk-linux-x64-gnu": "0.3.0",
    "@tuntundev/sdk-linux-arm64-gnu": "0.3.0",
    "@tuntundev/sdk-darwin-x64": "0.3.0",
    "@tuntundev/sdk-darwin-arm64": "0.3.0",
    "@tuntundev/sdk-win32-x64-msvc": "0.3.0",
    "@tuntundev/sdk-win32-arm64-msvc": "0.3.0",
    "@tuntundev/sdk-linux-x64-musl": "0.3.0",
    "@tuntundev/sdk-linux-arm64-musl": "0.3.0"
  }
}
